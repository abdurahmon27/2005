{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    // Allow type `any` without errors
    "@typescript-eslint/no-explicit-any": "off",

    // Allow unused variables and imports without errors
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": "off",

    // Allow let declarations without requiring const
    "prefer-const": "off",

    // Optional additional rules (customizable)
    "no-console": "warn",
    "no-debugger": "warn",
    "react-hooks/rules-of-hooks": "off"
  }
}
